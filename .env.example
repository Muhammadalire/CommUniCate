# DEEPGRAM_API_KEY: Required for STT (Nova-3).
DEEPGRAM_API_KEY="your_deepgram_api_key_here"

# GROQ_API_KEY: Required for LLM (Llama 3.3 via Groq).
GROQ_API_KEY="your_groq_api_key_here"

# NEXT_PUBLIC_DEEPGRAM_API_KEY: Used client-side for real-time STT WebSocket.
NEXT_PUBLIC_DEEPGRAM_API_KEY="your_deepgram_api_key_here"

# FISH_AUDIO_API_KEY: Required for TTS.
FISH_AUDIO_API_KEY="your_fish_audio_api_key_here"
